# Unreal Engine generated folders
/Binaries/
/Intermediate/
/Saved/
/DerivedDataCache/
/Build/

# Plugin generated folders
/Plugins/**/Binaries/
/Plugins/**/Intermediate/
/Plugins/**/Saved/

# IDE and generated project files
/.vs/
/.idea/
/.vscode/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj/
*.xcworkspace/
*.code-workspace
*.DotSettings.user
.vsconfig

# Python caches
__pycache__/
*.py[cod]

# Unreal local logs, backups, autosaves, screenshots, and crash data
*.log
*.tmp
*.bak
*.backup
*.autosave
*.dmp
CrashReportClient/

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Local working documents. Only the two delivered planning docs are tracked.
/docs/*
!/docs/
!/docs/策划须知.md
!/docs/如何配置.md

# Keep UE project content/config/source/assets tracked.
# Do not ignore binary content assets such as .uasset and .umap.
