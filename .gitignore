# Unreal Engine generated folders
/Binaries/*
!/Binaries/
!/Binaries/Win64/
/Binaries/Win64/*
!/Binaries/Win64/ToyTowerDefenseEditor.target
!/Binaries/Win64/UnrealEditor-ToyTowerDefense.dll
!/Binaries/Win64/UnrealEditor.modules
/Intermediate/
/Saved/
/DerivedDataCache/
/Build/

# Plugin generated folders
/Plugins/**/Binaries/*
!/Plugins/GameplayMessageRouter/Binaries/
!/Plugins/GameplayMessageRouter/Binaries/Win64/
/Plugins/GameplayMessageRouter/Binaries/Win64/*
!/Plugins/GameplayMessageRouter/Binaries/Win64/UnrealEditor-GameplayMessageNodes.dll
!/Plugins/GameplayMessageRouter/Binaries/Win64/UnrealEditor-GameplayMessageRuntime.dll
!/Plugins/GameplayMessageRouter/Binaries/Win64/UnrealEditor.modules
/Plugins/**/Intermediate/
/Plugins/**/Saved/

# IDE and generated project files
/.vs/
/.idea/
/.vscode/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj/
*.xcworkspace/
*.code-workspace
*.DotSettings.user
.vsconfig

# Python caches
__pycache__/
*.py[cod]

# Unreal local logs, backups, autosaves, screenshots, and crash data
*.log
*.tmp
*.bak
*.backup
*.autosave
*.dmp
CrashReportClient/

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Local working documents. Only the two delivered planning docs are tracked.
/docs/*
!/docs/
!/docs/策划须知.md
!/docs/如何配置.md
!/docs/免编译打开说明.md

# Keep UE project content/config/source/assets tracked.
# Do not ignore binary content assets such as .uasset and .umap.
